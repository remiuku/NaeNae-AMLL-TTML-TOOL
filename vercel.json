{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"rewrites": [
		{
			"source": "/boykisser/(.*)",
			"destination": "https://files.catbox.moe/$1"
		}
	],
	"headers": [
		{
			"source": "(.*)",
			"headers": [
				{
					"key": "Cross-Origin-Opener-Policy",
					"value": "same-origin"
				},
				{
					"key": "Cross-Origin-Embedder-Policy",
					"value": "require-corp"
				}
			]
		}
	]
}
